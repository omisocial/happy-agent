# TikTok Connect Configuration

# Chrome Profile directory (absolute path)
CHROME_PROFILES_DIR=./chrome_profiles

# Rate limiting (milliseconds)
DELAY_BETWEEN_CREATORS=5000
DELAY_BETWEEN_PROFILES=10000

# Retry
MAX_RETRIES=3
MAX_HEAL_ATTEMPTS=3

# Mode: headed (show browser) or headless
HEADLESS=false

# Dry run mode (don't actually send invites)
DRY_RUN=true

# TikTok Shop URL
TIKTOK_AFFILIATE_URL=https://partner.tiktokshop.com/affiliate-cmp/creator/market=7

# AI Healer command (customize based on your AI agent CLI)
HEALER_COMMAND=npx agent-browser fix
